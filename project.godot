; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Leal"
run/main_scene="uid://1dqlv1s1j788"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=200
config/icon="res://icon.svg"

[display]

window/vsync/vsync_mode=0

[file_customization]

folder_colors={
"res://assets/": "red",
"res://assets/font/": "blue",
"res://assets/sprites/": "green",
"res://assets/sprites/Player/": "purple",
"res://assets/sprites/VFX/": "red",
"res://assets/tilemaps/": "yellow",
"res://scenes/": "teal",
"res://scenes/Player/": "purple",
"res://scenes/Player/FX/": "red",
"res://scripts/": "orange",
"res://scripts/tools/": "purple",
"res://shaders/": "pink"
}

[global_group]

Player="The playable character"
Interact="The prompt that tells you when you can interact"
Area="The Area we are in."
GameManager="Keeps track of the data and progress of the game"
FadeOverlay="Fade in and fade out screen!"

